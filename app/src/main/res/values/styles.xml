<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SpendWise.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_green</item>
        <item name="hintTextColor">@color/brand_green</item>
    </style>

    <style name="NavTextActive">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="NavTextInactive">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="SwitchGreen" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="colorControlActivated">#00C896</item>
        <item name="colorSwitchThumbNormal">#FFFFFF</item>
        <item name="android:colorForeground">#D1FAE5</item>
    </style>
    <style name="SwitchIndigo" parent="SwitchGreen" />
</resources>